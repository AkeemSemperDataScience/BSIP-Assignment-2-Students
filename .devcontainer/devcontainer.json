{
  "name": "Basic Stats in Python Assignment 2",
  "dockerComposeFile": "docker-compose.yml",
  "service": "ml-notebooks",
  "workspaceFolder": "/workspace",

  // VS Code extensions installed inside the container
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter",
        "ms-toolsai.jupyter-renderers",
        "ms-toolsai.vscode-jupyter-cell-tags",
        "ms-toolsai.vscode-jupyter-slideshow"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "jupyter.notebookFileRoot": "/workspace"
      }
    }
  },

  // Forward Jupyter and TensorBoard ports
  "forwardPorts": [8888, 6006],

  // Run after the container starts
  "postStartCommand": "echo 'Container ready. Run: jupyter lab --ip=0.0.0.0 --port=8888 --no-browser --allow-root'"
}
